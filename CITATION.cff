    given-names: "Felipe Maya"
    email: "felipe@truthagi.ai"
version: "0.1.0"
date-released: "2026-03-22"
license: "AGPL-3.0-or-later"
repository-code: "https://github.com/gnai-creator/drm-transformer"
keywords:
  - drm
  - geodesic-attention
  - riemannian-manifold
  - gravitational-transformer
  - variable-dimensionality
